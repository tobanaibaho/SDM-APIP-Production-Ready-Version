# =====================================================
# .env.example — Konfigurasi Sistem SDM APIP
# Salin file ini menjadi .env dan isi dengan nilai asli
# =====================================================

# ─── 1. IDENTITAS & DOMAIN APLIKASI ───────────────
DOMAIN_NAME=sdm.kemenkoinfra.go.id
FRONTEND_URL=https://sdm.kemenkoinfra.go.id
ALLOWED_ORIGINS=https://sdm.kemenkoinfra.go.id,https://www.sdm.kemenkoinfra.go.id

# ─── 2. KUNCI KEAMANAN SISTEM ─────────────────────
# WAJIB: Ganti dengan teks acak yang panjang (Minimal 64 karakter)
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_MIN_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_STRING_LAIN_MIN_64_KARAKTER

# ─── 3. KONFIGURASI DATABASE ──────────────────────
# WAJIB: Ganti password database
DB_USER=sdm_admin
DB_PASSWORD=GANTI_DENGAN_PASSWORD_DB_YANG_KUAT
DB_NAME=sdm_apip_db

# ─── 4. AKUN ADMIN UTAMA (Tanpa SSO) ──────────────
# WAJIB: Ganti password default untuk Admin Kepegawaian (HR)
ADMIN_DEFAULT_PASSWORD=GANTI_DENGAN_PASSWORD_ADMIN_YANG_KUAT

# ─── 5. KONEKSI LOGIN SSO (OIDC) ──────────────────
# Minta data ini ke tim IT Pusat / Infrastruktur Kementerian
SSO_ENABLED=true
SSO_CLIENT_ID=ISI_CLIENT_ID_DARI_TIM_IT
SSO_CLIENT_SECRET=ISI_CLIENT_SECRET_DARI_TIM_IT
SSO_ISSUER_URL=https://sso.kemenkoinfra.go.id/realms/pegawai
SSO_REDIRECT_URL=https://sdm.kemenkoinfra.go.id/api/auth/sso/oidc-callback

# ─── 6. PENGATURAN EMAIL (SMTP) ───────────────────
# Untuk fitur pengiriman tautan "Lupa Sandi"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=email-resmi@kemenkoinfra.go.id
SMTP_PASSWORD=APP_PASSWORD_EMAIL_RESMI
SMTP_FROM=email-resmi@kemenkoinfra.go.id
SMTP_FROM_NAME=SDM APIP System
