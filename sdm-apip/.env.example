# =====================================================
# .env.example — Salin file ini menjadi .env
# dan isi dengan nilai sebenarnya
#
# PERINGATAN: Jangan pernah commit file .env
# ke repository Git!
# =====================================================

# ─── DATABASE ─────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=sdm_admin
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
DB_NAME=sdm_apip_db
DB_SSLMODE=disable

# ─── JWT (Gunakan: openssl rand -hex 32) ──────────
JWT_SECRET=GANTI_DENGAN_RANDOM_STRING_MIN_32_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_STRING_LAIN_MIN_32_KARAKTER
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# ─── SERVER ───────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=release

# ─── CORS (URL frontend yang diizinkan) ───────────
ALLOWED_ORIGINS=https://DOMAIN_ANDA.com,https://www.DOMAIN_ANDA.com
FRONTEND_URL=https://DOMAIN_ANDA.com

# ─── SMTP (Email) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=email@gmail.com
SMTP_PASSWORD=app_password_google_16_karakter
SMTP_FROM=email@gmail.com
SMTP_FROM_NAME=SDM APIP System
SMTP_INSECURE=false

# ─── ADMIN BOOTSTRAP ──────────────────────────────
# Password default admin saat pertama kali sistem dijalankan
# WAJIB diisi sebelum deployment pertama!
ADMIN_DEFAULT_PASSWORD=GANTI_DENGAN_PASSWORD_ADMIN_KUAT

# ─── LOGGING ──────────────────────────────────────
LOG_FILE_PATH=logs/app.log
